{
  "title": "Uptime Monitor & API Health",
  "uid": "uptime-001",
  "refresh": "10s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Website Uptime Status (1 = UP, 0 = DOWN)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "uptime_monitor_up", "legendFormat": "{{url}}"}],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Avg Ping Latency (seconds)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "rate(uptime_monitor_response_duration_seconds_sum[1m]) / rate(uptime_monitor_response_duration_seconds_count[1m])", "legendFormat": "{{url}}"}],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "id": 3,
      "title": "API Request Rate (per sec)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 7},
      "targets": [{"expr": "sum(rate(http_requests_total[1m])) by (method, path, status)", "legendFormat": "{{method}} {{path}} ({{status}})"}],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "Go Goroutines Count",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 7},
      "targets": [{"expr": "go_goroutines", "legendFormat": "Goroutines"}]
    },
    {
      "id": 5,
      "title": "Go Memory Allocated (Bytes)",
      "type": "timeseries",
      "gridPos": {"x": 18, "y": 8, "w": 6, "h": 7},
      "targets": [{"expr": "go_memstats_alloc_bytes", "legendFormat": "Alloc Memory"}]
    },
    {
      "id": 6,
      "title": "API Container Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {"x": 0, "y": 15, "w": 24, "h": 10},
      "targets": [{"expr": "{container=~\"uptime-monitor-api.*|.*-api-.*\"}", "refId": "A"}],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true
      }
    }
  ]
}
